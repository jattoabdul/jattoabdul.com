# Local dev port for `next dev` (Next picks 3000 by default; set to override).
PORT=3005

# ──────────────────────────────────────────────────────────────────────────
# Medium RSS sync
# ──────────────────────────────────────────────────────────────────────────
# When "true", the homepage and /writing page fetch posts from
#   https://medium.com/feed/@jattoabdul
# via api.rss2json.com (server-side, ISR-cached for 1h) and merge them with
# local posts. Failures degrade gracefully: local posts still render and the
# /writing page shows the "Couldn’t load Medium posts right now" banner.
#
# Leave unset (or "false") to render local posts only — no network calls
# happen during build or runtime.
NEXT_PUBLIC_ENABLE_MEDIUM_FEED=true

# ──────────────────────────────────────────────────────────────────────────
# Hero variant
# ──────────────────────────────────────────────────────────────────────────
# "terminal" (default) or "editorial". Sets the homepage hero.
# Build-time only — change requires a rebuild.
NEXT_PUBLIC_HERO_VARIANT=terminal

# ──────────────────────────────────────────────────────────────────────────
# Newsletter (optional)
# ──────────────────────────────────────────────────────────────────────────
# The /api/subscribe route currently no-ops (returns 200) so the form flow
# works end-to-end. Wire it to your provider by reading these and forwarding
# from src/app/api/subscribe/route.ts.
# NEWSLETTER_PROVIDER=buttondown
# NEWSLETTER_API_KEY=
