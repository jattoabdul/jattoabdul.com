# Local dev port for `next dev` (Next picks 3000 by default; set to override).
PORT=3005

# ──────────────────────────────────────────────────────────────────────────
# Medium RSS sync
# ──────────────────────────────────────────────────────────────────────────
# When "true", the homepage and /writing page fetch posts from
#   https://medium.com/feed/@jattoabdul
# via api.rss2json.com (server-side, ISR-cached for 1h) and merge them with
# local posts. Failures degrade gracefully: local posts still render and the
# /writing page shows the "Couldn’t load Medium posts right now" banner.
#
# Leave unset (or "false") to render local posts only — no network calls
# happen during build or runtime.
NEXT_PUBLIC_ENABLE_MEDIUM_FEED=true

# ──────────────────────────────────────────────────────────────────────────
# YouTube channel feed
# ──────────────────────────────────────────────────────────────────────────
# When BOTH are set, the homepage Latest Videos section and /videos page
# pull the channel's most recent ~15 videos from
#   https://www.youtube.com/feeds/videos.xml?channel_id=UC...
# via Atom RSS (no API key, server-side, ISR-cached for 1h). On failure or
# when disabled, falls back to the manually curated list in src/data/videos.ts.
#
# Note: Atom feed gives title, link, thumbnail, published date, and video ID.
# It does NOT include duration or view counts (those need YouTube Data API).
# Duration is hidden when missing.
#
# To find your channel ID:
#   1. Visit your channel (youtube.com/@your-handle)
#   2. View page source, search for "channelId" — it's a 24-char string
#      starting with "UC"
#   3. Or use https://commentpicker.com/youtube-channel-id.php
NEXT_PUBLIC_ENABLE_YOUTUBE_FEED=false
# YOUTUBE_CHANNEL_ID=

# ──────────────────────────────────────────────────────────────────────────
# Hero variant
# ──────────────────────────────────────────────────────────────────────────
# "terminal" (default) or "editorial". Sets the homepage hero.
# Build-time only — change requires a rebuild.
# Runtime override (no rebuild needed): visit /?hero=editorial OR run
#   localStorage.setItem('hero', 'editorial'); location.reload();
NEXT_PUBLIC_HERO_VARIANT=terminal

# ──────────────────────────────────────────────────────────────────────────
# Newsletter — Resend Audiences
# ──────────────────────────────────────────────────────────────────────────
# When BOTH are set, /api/subscribe creates the contact in your Resend
# Audience. With either missing, the endpoint stays in stub mode (returns 200
# so the UI flow still works in dev).
#
# 1. Create a free Resend account: https://resend.com
# 2. API key (server-only — DO NOT prefix with NEXT_PUBLIC_):
#    Dashboard → API Keys → Create. Scope it to "Sending access" + "Full access
#    to Audiences" (or just Audiences if you don't send from this app yet).
# 3. Audience ID:
#    Dashboard → Audiences → New Audience → copy the ID from the URL.
# RESEND_API_KEY=
# RESEND_AUDIENCE_ID=
