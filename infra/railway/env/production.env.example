# Production environment variables for the jattoabdul.com Railway service.
#
# These mirror env.example at the repo root. Set them in:
#   Railway → Project → Service → Variables
#
# Copy values from your local .env.development.local (or the workspace .env)
# into the Railway dashboard. Do NOT commit real values into this file.

# ── Runtime ──────────────────────────────────────────────────────────────
# Railway injects PORT at runtime; no need to set it manually unless you
# explicitly want to override.

# ── Medium RSS sync ──────────────────────────────────────────────────────
NEXT_PUBLIC_ENABLE_MEDIUM_FEED=true

# ── YouTube channel feed ─────────────────────────────────────────────────
NEXT_PUBLIC_ENABLE_YOUTUBE_FEED=true
YOUTUBE_CHANNEL_ID=UCJBv-ovzj7Q_N0JpXwAy-Bg

# ── Hero variant ─────────────────────────────────────────────────────────
NEXT_PUBLIC_HERO_VARIANT=terminal

# ── Resend (newsletter) ──────────────────────────────────────────────────
# Server-only — DO NOT prefix with NEXT_PUBLIC_.
RESEND_API_KEY=
RESEND_AUDIENCE_ID=
